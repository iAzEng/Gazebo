<?xml version="1.0" ?>
<!--
  ============================================================
  SOLUTION — my_first_world.sdf
  Session 01 Exercise Reference Solution
  ============================================================
  Includes:
    - 4 static objects + 1 dynamic object
    - A 2-link model connected by a revolute joint
    - One model loaded from Gazebo Fuel via <include>
  ============================================================
-->
<sdf version="1.10">
  <world name="my_first_world">

    <physics name="1ms" type="ignored">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1.0</real_time_factor>
    </physics>

    <plugin filename="gz-sim-physics-system"
            name="gz::sim::systems::Physics"/>
    <plugin filename="gz-sim-user-commands-system"
            name="gz::sim::systems::UserCommands"/>
    <plugin filename="gz-sim-scene-broadcaster-system"
            name="gz::sim::systems::SceneBroadcaster"/>

    <!-- Sun -->
    <light type="directional" name="sun">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 10 0 0 0</pose>
      <diffuse>1.0 0.95 0.8 1</diffuse>
      <specular>0.4 0.4 0.3 1</specular>
      <attenuation>
        <range>1000</range>
        <constant>0.9</constant>
        <linear>0.01</linear>
        <quadratic>0.001</quadratic>
      </attenuation>
      <direction>-0.5 0.1 -0.9</direction>
    </light>

    <!-- Ground Plane -->
    <model name="ground_plane">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry>
            <plane><normal>0 0 1</normal></plane>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>100 100</size>
            </plane>
          </geometry>
          <material>
            <ambient>0.5 0.5 0.5 1</ambient>
            <diffuse>0.5 0.5 0.5 1</diffuse>
            <specular>0.1 0.1 0.1 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- Object 1: Red Box -->
    <model name="red_box">
      <static>true</static>
      <pose>0 0 0.75 0 0 0</pose>
      <link name="link">
        <visual name="visual">
          <geometry>
            <box><size>1.5 1.5 1.5</size></box>
          </geometry>
          <material>
            <ambient>0.9 0.1 0.1 1</ambient>
            <diffuse>0.9 0.1 0.1 1</diffuse>
            <specular>0.3 0.0 0.0 1</specular>
          </material>
        </visual>
        <collision name="collision">
          <geometry>
            <box><size>1.5 1.5 1.5</size></box>
          </geometry>
        </collision>
      </link>
    </model>

    <!-- Object 2: Blue Cylinder -->
    <model name="blue_cylinder">
      <static>true</static>
      <pose>3 0 1.0 0 0 0</pose>
      <link name="link">
        <visual name="visual">
          <geometry>
            <cylinder>
              <radius>0.6</radius>
              <length>2.0</length>
            </cylinder>
          </geometry>
          <material>
            <ambient>0.1 0.2 0.9 1</ambient>
            <diffuse>0.1 0.2 0.9 1</diffuse>
            <specular>0.0 0.0 0.4 1</specular>
          </material>
        </visual>
        <collision name="collision">
          <geometry>
            <cylinder>
              <radius>0.6</radius>
              <length>2.0</length>
            </cylinder>
          </geometry>
        </collision>
      </link>
    </model>

    <!-- Object 3: Green Sphere -->
    <model name="green_sphere">
      <static>true</static>
      <pose>-3 0 0.8 0 0 0</pose>
      <link name="link">
        <visual name="visual">
          <geometry>
            <sphere><radius>0.8</radius></sphere>
          </geometry>
          <material>
            <ambient>0.1 0.8 0.1 1</ambient>
            <diffuse>0.1 0.8 0.1 1</diffuse>
            <specular>0.0 0.3 0.0 1</specular>
          </material>
        </visual>
        <collision name="collision">
          <geometry>
            <sphere><radius>0.8</radius></sphere>
          </geometry>
        </collision>
      </link>
    </model>

    <!-- Object 4: Orange Cylinder (on its side) -->
    <model name="orange_log">
      <static>true</static>
      <pose>0 4 0.35 1.5708 0 0</pose>
      <link name="link">
        <visual name="visual">
          <geometry>
            <cylinder>
              <radius>0.35</radius>
              <length>3.0</length>
            </cylinder>
          </geometry>
          <material>
            <ambient>1.0 0.5 0.0 1</ambient>
            <diffuse>1.0 0.5 0.0 1</diffuse>
            <specular>0.4 0.2 0.0 1</specular>
          </material>
        </visual>
        <collision name="collision">
          <geometry>
            <cylinder>
              <radius>0.35</radius>
              <length>3.0</length>
            </cylinder>
          </geometry>
        </collision>
      </link>
    </model>

    <!-- Dynamic Object: Purple Sphere (falls on play) -->
    <model name="dynamic_purple_sphere">
      <pose>0 -4 6 0 0 0</pose>
      <link name="link">
        <inertial>
          <mass>2.0</mass>
          <inertia>
            <ixx>0.128</ixx><ixy>0</ixy><ixz>0</ixz>
            <iyy>0.128</iyy><iyz>0</iyz>
            <izz>0.128</izz>
          </inertia>
        </inertial>
        <visual name="visual">
          <geometry>
            <sphere><radius>0.4</radius></sphere>
          </geometry>
          <material>
            <ambient>0.6 0.0 0.9 1</ambient>
            <diffuse>0.6 0.0 0.9 1</diffuse>
            <specular>0.3 0.0 0.5 1</specular>
          </material>
        </visual>
        <collision name="collision">
          <geometry>
            <sphere><radius>0.4</radius></sphere>
          </geometry>
        </collision>
      </link>
    </model>

    <!-- 2-Link Model with a Revolute Joint -->
    <model name="simple_arm">
      <pose>-6 0 0 0 0 0</pose>

      <link name="base_link">
        <pose>0 0 0.5 0 0 0</pose>
        <inertial>
          <mass>5.0</mass>
          <inertia>
            <ixx>0.1</ixx><ixy>0</ixy><ixz>0</ixz>
            <iyy>0.1</iyy><iyz>0</iyz><izz>0.1</izz>
          </inertia>
        </inertial>
        <visual name="visual">
          <geometry>
            <box><size>0.4 0.4 1.0</size></box>
          </geometry>
          <material>
            <ambient>0.3 0.3 0.8 1</ambient>
            <diffuse>0.3 0.3 0.8 1</diffuse>
            <specular>0.1 0.1 0.3 1</specular>
          </material>
        </visual>
        <collision name="collision">
          <geometry>
            <box><size>0.4 0.4 1.0</size></box>
          </geometry>
        </collision>
      </link>

      <link name="arm_link">
        <pose>0 0 1.6 0 0 0</pose>
        <inertial>
          <mass>1.0</mass>
          <inertia>
            <ixx>0.02</ixx><ixy>0</ixy><ixz>0</ixz>
            <iyy>0.1</iyy><iyz>0</iyz><izz>0.1</izz>
          </inertia>
        </inertial>
        <visual name="visual">
          <geometry>
            <cylinder>
              <radius>0.1</radius>
              <length>1.2</length>
            </cylinder>
          </geometry>
          <material>
            <ambient>0.8 0.3 0.1 1</ambient>
            <diffuse>0.8 0.3 0.1 1</diffuse>
            <specular>0.3 0.1 0.0 1</specular>
          </material>
        </visual>
        <collision name="collision">
          <geometry>
            <cylinder>
              <radius>0.1</radius>
              <length>1.2</length>
            </cylinder>
          </geometry>
        </collision>
      </link>

      <joint name="arm_joint" type="revolute">
        <pose relative_to="arm_link">0 0 -0.6 0 0 0</pose>
        <parent>base_link</parent>
        <child>arm_link</child>
        <axis>
          <xyz expressed_in="__model__">0 0 1</xyz>
          <limit>
            <lower>-3.1416</lower>
            <upper>3.1416</upper>
          </limit>
        </axis>
      </joint>

      <joint name="base_to_world" type="fixed">
        <parent>world</parent>
        <child>base_link</child>
      </joint>

    </model>

    <!-- External model from Gazebo Fuel -->
    <include>
      <uri>https://fuel.gazebosim.org/1.0/OpenRobotics/models/Coke</uri>
      <name>coke_can</name>
      <pose>2 -3 0 0 0 0</pose>
    </include>

  </world>
</sdf>
